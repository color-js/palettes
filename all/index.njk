---
title: "Filter Palettes by Hue"
includes: '<link rel="stylesheet" href="./style.css" /><script src="./hue-range.js" type="module"></script>'
---

<h1>Filter Palettes by Hue</h1>

<p>
	A single chart and the color scales of <strong>all palettes</strong>, filtered by hue.
	A scale is included when the hue (H) of its <strong>key color</strong> — the color with the
	maximum chroma — falls within <em>extent</em> degrees of the slider's <em>center</em> hue.
	Since hue is circular, the range wraps around 0° automatically; an extent of 180° includes
	everything. You can also limit the chart to a region of the visible axes — scales that fall
	entirely outside that region are dropped from the list below.
</p>

<form id="hue-filter" aria-label="Filter by hue">
	<label class="slider-label">
		Center hue
		<channel-slider id="h-center" space="oklch-p3" channel="h" color="color(oklch-p3 0.7 1 0)" value="0"></channel-slider>
	</label>
	<label>± <input type="number" id="h-extent" min="0" max="180" step="1" value="180">°</label>
	<output id="match-count" for="h-center h-extent"></output>
</form>

<h2 id="chart-section">
	<space-picker value="oklch"></space-picker>
	Chart
</h2>
<details id="axis-region">
	<summary>Limit to region</summary>
	<form id="axis-filter" aria-label="Limit to a region of the chart axes">
		<label><span class="axis-name" data-axis="x">X</span>
			<input type="number" id="x-min" step="any" placeholder="min">
			<span>–</span>
			<input type="number" id="x-max" step="any" placeholder="max">
		</label>
		<label><span class="axis-name" data-axis="y">Y</span>
			<input type="number" id="y-min" step="any" placeholder="min">
			<span>–</span>
			<input type="number" id="y-max" step="any" placeholder="max">
		</label>
		<button type="reset">Reset</button>
	</form>
</details>
<color-chart y="oklch.c" x="oklch.l" info="L: oklch.l, C: oklch.c, H: oklch.h">
	{% for id, palette in palettes %}
		{% for hue, scale in palette.colors %}
			{%- if hue != "other" -%}
			<color-scale
				class="key-scale"
				data-palette="{{ id }}"
				data-hue="{{ hue }}"
				data-key-hue="{{ palette.colors_oklch[hue] | keyHue }}"
				colors="{{ scale | serializeObject }}"></color-scale>
			{%- endif -%}
		{% endfor %}
	{% endfor %}
</color-chart>

<h2 id="scales-section">
	<space-picker value="oklch"></space-picker>
	Color Scales
</h2>
<table id="scales">
<thead>
	<tr>
		<th>Palette</th>
		<th>Hue</th>
		<th style="width: 100%">Scale</th>
	</tr>
</thead>
<tbody>
	{% for id, palette in palettes %}
		{% for hue, scale in palette.colors %}
			{%- if hue != "other" -%}
			{%- set keyHueValue = palette.colors_oklch[hue] | keyHue -%}
			<tr class="key-scale-row" data-palette="{{ id }}" data-hue="{{ hue }}" data-key-hue="{{ keyHueValue }}">
				<th><a href="../palettes/{{ id }}/#{{ hue }}">{{ palette.name }}</a></th>
				<th>
					{%- if hues[hue].palette_count > 1 -%}
					<a href="../hues/{{ hue }}/">{{ hues[hue].name }}</a>
					{%- else -%}
					{{ hue }}
					{%- endif -%}
					<small>{{ keyHueValue | number({ maximumFractionDigits: 0 }) }}°</small>
				</th>
				<td><color-scale colors="{{ scale | serializeObject }}" info="L: oklch.l, C: oklch.c, H: oklch.h"></color-scale></td>
			</tr>
			{%- endif -%}
		{% endfor %}
	{% endfor %}
</tbody>
</table>
